# ─── Server ───────────────────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=false

# ─── Database (Supabase / PostgreSQL) ────────────────────────────────────────
DB_HOST=your-supabase-host.supabase.com
DB_PORT=5432
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-db-password
DB_NAME=postgres
DB_SSLMODE=require

# ─── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=minicpm-v:8b
OLLAMA_TIMEOUT=120

# ─── Storage ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=data/uploads
IMAGES_DIR=data/images
RESULTS_DIR=data/results

# ─── OCR Settings ─────────────────────────────────────────────────────────────
OCR_MAX_IMAGE_WIDTH=1920
OCR_DPI=200
OCR_TEMPERATURE=0.1
OCR_MAX_RETRIES=3
OCR_INTER_CALL_DELAY_MS=500

# ─── OCR Provider & Gemini ────────────────────────────────────────────────────
OCR_PROVIDER=ollama
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

